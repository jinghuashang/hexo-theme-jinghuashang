<footer class="site-footer">
  <div class="footer-content">
    <div class="footer-main">
      <div class="footer-info">
        <div class="footer-brand">
          <span class="footer-logo"><%= config.title %></span>
          <span class="footer-year">&copy; <%= theme.footer.startYear || '2024' %> - <%= date(new Date(), 'YYYY') %></span>
        </div>
        <div class="footer-hitokoto">
          <span class="hitokoto-prefix">//</span>
          <span class="hitokoto-text" id="hitokoto-text">正在加载一言...</span>
          <span class="hitokoto-cursor">|</span>
