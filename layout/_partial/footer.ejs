          </svg>
          <span>GitHub</span>
        </a>
        <a class="footer-link footer-subscribe" href="<%= url_for(theme.footer.atom || '/atom.xml') %>" target="_blank">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
            <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.37 20 6.18 20c-1.19 0-2.18-.99-2.18-2.18 0-1.19.99-2.18 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
          </svg>
          <span>订阅</span>
        </a>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="footer-records">
        <% if (theme.footer.icp) { %>
          <a class="record-link" href="https://beian.miit.gov.cn/" target="_blank" rel="noopener"><%= theme.footer.icp %></a>
        <% } %>
        <% if (theme.footer.mian) { %>
          <a class="record-link" href="https://www.mian.gov.cn/" target="_blank" rel="noopener"><%= theme.footer.mian %></a>
        <% } %>
      </div>
      <div class="footer-license">
        <% if (theme.footer.cc) { %>
          <a class="license-link" href="<%= theme.footer.cc %>" target="_blank" rel="noopener">
            CC BY-NC-SA 4.0
          </a>
        <% } %>
      </div>
    </div>
  </div>
</footer>

<script>
(function() {
  const hitokotoEl = document.getElementById('hitokoto-text');
  if (!hitokotoEl) return;

  const typingSpeed = 100;
  const deletingSpeed = 30;
  const pauseAfterType = 2000;
  const pauseAfterDelete = 500;

  let currentText = '';
  let isDeleting = false;
  let charIndex = 0;

  const defaultSentences = [
    '生命中真正困难的不是找答案，而是提出正确的问题。',
    '世界上只有一种英雄主义，就是看清生活的真相之后依然热爱生活。',
    '我们仰望着同一片天空，却看着不同的地方。',
    '不要因为走得太远，而忘记为什么出发。',
    '你不能左右天气，但可以改变心情。',
    '今天的努力，是明天的收获。',
    '梦想不会逃跑，逃跑的永远是自己。',
    '生活不是等待暴风雨过去，而是学会在雨中跳舞。'
  ];

  let sentences = defaultSentences;
  let currentSentenceIndex = 0;

  // Fetch from hitokoto API
  fetch('https://v1.hitokoto.cn/?c=d&c=h&c=i&c=k')
    .then(res => res.json())
    .then(data => {
      if (data && data.hitokoto) {
        sentences = [data.hitokoto, ...defaultSentences];
      }
    })
    .catch(() => {});

  function type() {
    const fullText = sentences[currentSentenceIndex];
    
    if (!isDeleting) {
      currentText = fullText.substring(0, charIndex + 1);
      charIndex++;
      
      hitokotoEl.textContent = currentText;
      
      if (charIndex === fullText.length) {
        isDeleting = true;
        setTimeout(type, pauseAfterType);
        return;
      }
      setTimeout(type, typingSpeed + Math.random() * 50);
    } else {
      currentText = fullText.substring(0, charIndex - 1);
      charIndex--;
      
      hitokotoEl.textContent = currentText || '\u00A0';
      
      if (charIndex === 0) {
        isDeleting = false;
        currentSentenceIndex = (currentSentenceIndex + 1) % sentences.length;
        setTimeout(type, pauseAfterDelete);
        return;
      }
      setTimeout(type, deletingSpeed);
    }
  }

  setTimeout(type, 1000);
})();
</script>
